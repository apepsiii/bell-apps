        <!-- MODAL: ADD POINT RULE -->
        <div id="modal-add-point-rule" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm animate-fade-in">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden transform transition-all scale-95" onclick="event.stopPropagation()">
                <div class="px-6 py-4 border-b flex justify-between items-center bg-slate-50">
                    <h3 class="font-bold text-lg text-slate-800">Tambah Aturan Poin</h3>
                    <button onclick="closeModal('modal-add-point-rule')" class="text-slate-400 hover:text-red-500 transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
                <div class="p-6">
                    <form action="/admin/point-rules/add" method="POST" onsubmit="submitAddPointRule(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Kategori</label>
                            <select name="category" class="w-full border rounded-lg p-2.5 bg-slate-50 focus:bg-white transition-colors" required>
                                <option value="achievement">Prestasi (Poin Positif)</option>
                                <option value="violation">Pelanggaran (Poin Negatif)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Nama Aturan</label>
                            <input type="text" name="name" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-100 outline-none transition-shadow" placeholder="Contoh: Datang Tepat Waktu" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Poin</label>
                            <input type="number" name="points" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-100 outline-none transition-shadow" placeholder="Contoh: 10 atau -5" required>
                            <p class="text-xs text-slate-500 mt-1">Gunakan angka negatif untuk pelanggaran.</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Deskripsi (Opsional)</label>
                            <textarea name="description" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-100 outline-none transition-shadow" rows="2"></textarea>
                        </div>
                        <div class="pt-2">
                            <button type="submit" class="w-full bg-blue-600 text-white rounded-lg py-2.5 hover:bg-blue-700 font-medium transition-colors shadow-lg shadow-blue-600/20">Simpan Aturan</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- MODAL: ADD REWARD -->
        <div id="modal-add-point-reward" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm animate-fade-in">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden transform transition-all scale-95" onclick="event.stopPropagation()">
                <div class="px-6 py-4 border-b flex justify-between items-center bg-slate-50">
                    <h3 class="font-bold text-lg text-slate-800">Tambah Hadiah (Reward)</h3>
                    <button onclick="closeModal('modal-add-point-reward')" class="text-slate-400 hover:text-red-500 transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
                <div class="p-6">
                    <form action="/admin/point-rewards/add" method="POST" onsubmit="submitAddPointReward(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Nama Hadiah</label>
                            <input type="text" name="name" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-emerald-100 outline-none transition-shadow" placeholder="Contoh: Voucher Kantin" required>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Biaya Poin</label>
                                <input type="number" name="points_cost" min="1" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-emerald-100 outline-none transition-shadow" placeholder="Contoh: 50" required>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Stok Awal</label>
                                <input type="number" name="stock" min="0" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-emerald-100 outline-none transition-shadow" placeholder="Contoh: 10" required>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Deskripsi (Opsional)</label>
                            <textarea name="description" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-emerald-100 outline-none transition-shadow" rows="2"></textarea>
                        </div>
                        <div class="pt-2">
                            <button type="submit" class="w-full bg-emerald-600 text-white rounded-lg py-2.5 hover:bg-emerald-700 font-medium transition-colors shadow-lg shadow-emerald-600/20">Simpan Hadiah</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
